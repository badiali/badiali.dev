---
import '@fontsource-variable/inter-tight';
interface Props {
	title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html
	class="size-full font-['Inter_Tight_Variable',system-ui,sans-serif]"
	lang="es"
>
	<head>
		<meta charset="UTF-8" />
		<meta
			name="description"
			content="Luis Badiali, Design Systems & Frontend Dev"
		/>
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.ico" />
		<title>{title}</title>
	</head>
	<body
		class="size-full relative w-full from-neutral-200/75 text-neutral-800 bg-[#F5F4EF]"
	>
		<slot />
	</body>
</html>

<style is:global>
	html,
	body,
	* {
		cursor:
			url('/assets/img/badialiMouse.svg') 2 1,
			auto;
	}
</style>
